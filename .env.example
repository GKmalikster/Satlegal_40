# ═══════════════════════════════════════════════════════════
# SatLegal Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# Database
MONGODB_URI=mongodb://localhost:27017/satlegal
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/satlegal

# Server
PORT=3000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Email (Nodemailer - use Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
FROM_EMAIL=noreply@satlegal.in
FROM_NAME=SatLegal

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# ── Anthropic / Claude API ────────────────────────────────────────────────────
# Powers the law classifier engine (replaces keyword matching with AI)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional: ms before classifier falls back to keyword engine (default: 8000)
# CLASSIFIER_TIMEOUT=8000

# Admin Account
# Run: node backend/scripts/create-admin.js   (after first deploy)
# Override with env vars before running the script:
ADMIN_EMAIL=admin@satlegal.in
ADMIN_PASSWORD=SatLegal@Admin2024
ADMIN_NAME=SatLegal Administrator
# Admin login URL: /auth/admin-login.html
