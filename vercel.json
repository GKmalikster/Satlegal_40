{
  "version": 2,
  "functions": {
    "api/analyse.js":                 { "maxDuration": 15 },
    "api/track.js":                   { "maxDuration": 10 },
    "api/admin/stats.js":             { "maxDuration": 10 },
    "api/admin/users.js":             { "maxDuration": 10 },
    "api/admin/lawyers.js":           { "maxDuration": 10 },
    "api/admin/inquiries.js":         { "maxDuration": 10 },
    "api/admin/analytics/summary.js": { "maxDuration": 10 }
  },
  "routes": [
    { "src": "/api/analyse",                 "dest": "/api/analyse.js" },
    { "src": "/api/admin-login",             "dest": "/api/admin-login.js" },
    { "src": "/api/feedback",                "dest": "/api/feedback.js" },
    { "src": "/api/admin-users",             "dest": "/api/admin-users.js" },
    { "src": "/api/track",                   "dest": "/api/track.js" },
    { "src": "/api/admin/stats",             "dest": "/api/admin/stats.js" },
    { "src": "/api/admin/users",             "dest": "/api/admin/users.js" },
    { "src": "/api/admin/lawyers",           "dest": "/api/admin/lawyers.js" },
    { "src": "/api/admin/inquiries",         "dest": "/api/admin/inquiries.js" },
    { "src": "/api/admin/analytics/summary", "dest": "/api/admin/analytics/summary.js" },
    { "src": "/(.*)",                        "dest": "/$1" }
  ]
}
